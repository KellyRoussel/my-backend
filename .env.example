# OpenAI API Keys (one per feature)
openai_bobobidou_key=sk-proj-...
openai_instaposter_key=sk-proj-...
openai_investment_key=sk-proj-...

# Google OAuth
google_client_id=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
google_client_secret=GOCSPX-...
auth_redirect_uri=https://your-backend.onrender.com/auth/callback
google_auth_url=https://accounts.google.com/o/oauth2/auth
google_token_url=https://oauth2.googleapis.com/token
google_user_info_url=https://www.googleapis.com/oauth2/v3/userinfo

# Instagram OAuth
insta_client_id=YOUR_INSTAGRAM_CLIENT_ID
insta_client_secret=YOUR_INSTAGRAM_CLIENT_SECRET
insta_auth_url=https://www.instagram.com/oauth/authorize
insta_token_url=https://api.instagram.com/oauth/access_token
insta_graph_api=https://graph.instagram.com/v23.0
insta_long_lived_token_url=https://graph.instagram.com/access_token

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))"
secret_key=YOUR_RANDOM_SECRET_KEY_MIN_32_CHARS
algorithm=HS256
access_token_expire_minutes=60
refresh_token_expire_days=30

# Database (PostgreSQL / Supabase)
database_url=postgresql://user:password@host:5432/dbname

# Investment feature
openfigi_api_key=YOUR_OPENFIGI_KEY
TAVILY_API_KEY=tvly-...
AGENT_RECURSION_LIMIT=50
INVESTMENT_MODEL=gpt-4.1

# Langfuse tracing (optional)
LANGFUSE_TRACING_ENABLED=false
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com
